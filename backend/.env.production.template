# Railway MySQL Database Configuration
# Your Railway MySQL connection details

DB_HOST=${{RAILWAY_PRIVATE_DOMAIN}}
DB_USER=root
DB_PASSWORD=${{MYSQL_ROOT_PASSWORD}}
DB_NAME=railway
DB_PORT=3306

# JWT Secret - CHANGE THIS TO A SECURE RANDOM STRING
JWT_SECRET=your-super-secure-jwt-secret-key-for-production-2024

# Server Configuration
PORT=3000
NODE_ENV=production

# Frontend URL - Update with your actual frontend domain
FRONTEND_URL=https://your-edukiz-app.vercel.app

# Optional: Railway provides these automatically
# RAILWAY_STATIC_URL=https://your-backend-service.railway.app
# RAILWAY_PUBLIC_DOMAIN=your-backend-service.railway.app