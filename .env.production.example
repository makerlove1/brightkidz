# Production Backend API URL
# Replace with your actual Railway public domain after deployment
# 
# To get your Railway public domain:
# 1. Go to Railway dashboard
# 2. Click on your brightkidz service
# 3. Go to "Networking" section
# 4. Click "Generate Domain"
# 5. Copy the generated URL (e.g., https://brightkidz-production-xxxx.railway.app)
# 6. Add /api to the end
#
# Example: VUE_APP_API_URL=https://brightkidz-production-a1b2.railway.app/api

VUE_APP_API_URL=https://your-railway-backend-url.railway.app/api